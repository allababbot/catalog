{
    "name": "catalog",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun ./server.ts",
        "dev:hot": "bun --hot ./server.ts",
        "serve": "bun ./server.ts",
        "build": "bun build ./index.html --outdir=dist --target=browser --minify && bun ./scripts/copy-public.ts",
        "test": "bun test",
